generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Review {
  id             String          @id @default(uuid())
  jobId          String
  reviewerId     String
  revieweeId     String
  revieweeType   RevieweeType
  rating         Int
  comment        String?
  status         ReviewStatus    @default(pending)
  createdAt      DateTime        @default(now())
  moderationLogs ModerationLog[]

  @@unique([reviewerId, jobId])
  @@map("reviews")
}

enum RevieweeType {
  professional
  client
}

enum ReviewStatus {
  pending
  approved
  rejected
}

model BannedWord {
  id        String   @id @default(uuid())
  word      String   @unique
  createdAt DateTime @default(now())

  @@map("banned_words")
}

enum ModerationActor {
  ai
  human
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model ModerationLog {
  id        String          @id @default(uuid())
  reviewId  String
  review    Review          @relation(fields: [reviewId], references: [id])
  decision  ReviewStatus
  reason    String
  decidedBy ModerationActor
  createdAt DateTime        @default(now())

  @@map("moderation_logs")
}
